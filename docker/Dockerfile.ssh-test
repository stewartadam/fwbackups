FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bzip2 \
        ca-certificates \
        gzip \
        openssh-client \
        openssh-server \
        rsync \
        tar \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --no-cache-dir "paramiko>=5.0.0,<6"

WORKDIR /workspace
COPY . /workspace

RUN chmod +x /workspace/docker/run-ssh-operations-test.sh

ENTRYPOINT ["/workspace/docker/run-ssh-operations-test.sh"]
